# Models (too large for git - use Git LFS)
*.h5
*.keras
*.pt
*.tflite
*.onnx
models/checkpoints/
models/logs/

# Data - DON'T PUSH to git (use Kaggle/Google Drive)
data/train/*
data/val/*
data/raw/*
!data/train/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Notebooks (keep only specific ones)
*.ipynb
!notebooks/*.ipynb

# Images (downloaded data)
*.jpg
*.jpeg
*.png
*.bmp

# Logs
*.log
logs/

# Temp files
*.tmp
temp/
